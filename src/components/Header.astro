---
import Navigation from "./Navigation.astro";
import Menu from "./Menu.astro";
import ThemeIcon from "./ThemeIcon.astro";
---

<header>
  <nav>
    <div class="header-controls">
      <Menu />
      <div class="theme-icon">
        <ThemeIcon />
      </div>
    </div>

    <Navigation />
  </nav>
</header>

<style>
  .header-controls {
    display: flex;
  }
  .theme-icon {
    margin-left: auto;
  }
</style>
