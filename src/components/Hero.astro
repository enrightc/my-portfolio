<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    display: block;
    min-height: calc(100vh - 84px);
    display: flex;
    align-items: center;
    padding-bottom: 5rem;
  }

  .hero::after {
    content: "";
    position: absolute;
    top: -10%;
    right: -5%;
    width: 480px;
    height: 480px;
    background: radial-gradient(
      circle,
      rgba(56, 189, 248, 0.12) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle, var(--border), 1px, transparent 1px);
    opacity: 0.65;
    pointer-events: none;
    background-size: 28px 28px;
  }

  .name-accent {
    color: var(--accent);
  }

  .hero h1 {
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    line-height: 1.1;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .hero-tag {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 1rem;
    background-color: rgba(56, 189, 248, 0.08);
    border: 1px solid rgba(56, 189, 248, 0.25);
    border-radius: 5px;
    padding: 0.25rem 0.75rem;
    display: inline-block;
  }

  .hero-sub {
    color: var(--muted);
    max-width: 560px;
    line-height: 1.7;
    font-size: 1.15rem;
    margin-bottom: 2.25rem;
  }

  .hero-sub strong {
    color: var(--text);
  }

  .hero-tag::before {
    content: "< ";
  }

  .hero-tag::after {
    content: " /> ";
  }

  .cta-btns {
    display: flex;
    gap: 2em;
    flex-wrap: wrap;
  }

  .btn {
    font-weight: bold;
    border-radius: var(--radius);
    padding: 0.75rem 1.5rem;
    cursor: pointer;
    text-decoration: none;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn-primary::after {
    content: " →";
    font-weight: bold;
  }

  .btn-primary:hover,
  .btn-primary:focus {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .btn-secondary {
    color: var(--text);

    border: 1px solid var(--border);
  }

  .btn-secondary:hover,
  .btn-secondary:focus {
    border: 1px solid var(--accent);
    opacity: 0.9;
    transform: translateY(-1px);
    background: rgba(56, 189, 248, 0.06);
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 2px;
    height: 36px;
    background: linear-gradient(to bottom, var(--muted), transparent);
  }
</style>

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-tag">Junior-Full-Stack-Developer</div>
      <h1>
        Hi I'm
        <br />
        <span class="name-accent">Charlie Enright</span>
      </h1>
      <p class="hero-sub">
        I build <strong>data-driven web applications</strong> that help people explore
        landscapes, heritage, and place — combining a background in <strong
          >archaeology and GIS</strong
        > with full-stack development. Based in Wales, UK.
      </p>

      <!-- CTA Buttons -->
      <div class="cta-btns">
        <a href="#projects" class="btn btn-primary">View Projects</a>
        <a href="#about" class="btn btn-secondary">About Me</a>
      </div>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-line"></div>
    scroll
  </div>
</section>
