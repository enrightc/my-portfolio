---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectList from "../../components/ProjectList.astro";

import "../../styles/global.css";

// A function to tell astro to build a page for each tag in the list of tags
// The getStaticPaths function returns an array of page routes, and all of the pages at those routes will use the same template defined in the file.
export async function getStaticPaths() {
  const allProjects = await getCollection("project"); // this will give an array of all the markdown files in the projects directory, with their frontmatter and content
  const uniqueTags = [
    ...new Set(allProjects.map((project) => project.data.tags).flat()),
  ];

  return uniqueTags.map((tag) => {
    const filteredProjects = allProjects.filter((project) =>
      project.data.tags.includes(tag),
    );
    return {
      params: { tag },
      props: { projects: filteredProjects },
    };
  });
}

// Get the tag from the URL
// Example: /tags/astro → tag = "astro"
const { tag } = Astro.params;

const { projects } = Astro.props; // this will give a list of all the projects that are passed in the getStaticPaths function, so it can filter them by tag and display only the ones that have the tag in their frontmatter
---

<BaseLayout>
  <main class="container">
    <h1>{tag}</h1>
    <p>Projects tagged with {tag}</p>
    <ul class="project-grid">
      {
        projects.map((project) => (
          <ProjectList
            url={`/projects/${project.id}/`}
            title={project.data.title}
            img={project.data.image.url}
            alt={project.data.image.alt}
            tags={project.data.tags}
          />
        ))
      }
    </ul>
  </main>
</BaseLayout>
