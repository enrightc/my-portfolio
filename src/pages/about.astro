---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "About Me";

const identity = {
  firstName: "Charlie",
  lastName: "Enright",
  Location: "Wales, UK",
  occupation: "aspiring web developer",
};

const skills = [
  { type: "frontend", name: "HTML" },
  { type: "frontend", name: "CSS" },
  { type: "frontend", name: "JavaScript" },
  { type: "frontend", name: "React" },
  { type: "frontend", name: "jQuery" },
  { type: "backend", name: "Python" },
  { type: "backend", name: "Django" },
  { type: "geospatial", name: "GIS" },
  { type: "geospatial", name: "Leaflet" },
  { type: "backend", name: "PostgreSQL" },
  { type: "backend", name: "AWS S3" },
];

const skillColor = "white";
---

<style define:vars={{ skillColor }}>
  .container {
    font-family: system-ui, sans-serif;
    line-height: 1.6;
  }

  .intro {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }
  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }
  .skills li {
    background: #4c7fe5;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    text-align: centre;
    color: var(--skillColor);
  }
</style>

<BaseLayout>
  <main class="container">
    <h1>{pageTitle}</h1>
    <p class="intro">
      Hi, I’m {identity.firstName} – An {identity.occupation} passionate about using
      technology to make the past more accessible and the present more intuitive.
    </p>

    <h2>Skills</h2>

    <ul class="skills">
      {
        skills
          .filter((skill) => skill.type === "frontend")
          .map((skill) => <li>{skill.name}</li>)
      }
    </ul>

    <ul class="skills">
      {
        skills
          .filter((skill) => skill.type === "backend")
          .map((skill) => <li>{skill.name}</li>)
      }
    </ul>

    <ul class="skills">
      {
        skills
          .filter((skill) => skill.type === "geospatial")
          .map((skill) => <li>{skill.name}</li>)
      }
    </ul>
  </main>
</BaseLayout>
