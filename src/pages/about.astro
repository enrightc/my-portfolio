---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "About Me";

const identity = {
  firstName: "Charlie",
  lastName: "Enright",
  Location: "Wales, UK",
  occupation: "aspiring web developer",
};

const skillGroups = [
  {
    label: "//frontend",
    items: ["HTML", "CSS", "JavaScript", "React", "jQuery"],
  },
  { label: "//backend", items: ["Python", "Django", "PostgreSQL", "AWS S3"] },
  { label: "//geospatial", items: ["GIS", "Leaflet"] },
];
---

<style>
  .container {
    font-family: system-ui, sans-serif;
    line-height: 1.6;
  }

  .intro {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }
  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }
  .skills li {
    background: #4c7fe5;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    text-align: centre;
    color: var(--skillColor);
  }
</style>

<BaseLayout>
  <main class="container">
    <h1>{pageTitle}</h1>
    <p class="intro">
      Hi, I’m {identity.firstName} – An {identity.occupation} passionate about using
      technology to make the past more accessible and the present more intuitive.
    </p>

    <h2>Skills</h2>

    {
      skillGroups.map((group) => (
        <div class="skills-group">
          <p class="skills-group-label">{group.label}</p>

          <ul class="skills-list">
            {group.items.map((item) => (
              <li class="skill-chip">{item}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </main>
</BaseLayout>
