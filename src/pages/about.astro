---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "A bit about me";

const identity = {
  firstName: "Charlie",
  lastName: "Enright",
  Location: "Wales, UK",
  occupation: "aspiring web developer",
};

const skillGroups = [
  {
    label: "//   frontend",
    items: ["HTML", "CSS", "JavaScript", , "Astro", "React", "jQuery"],
    chipClass: "accent",
  },
  {
    label: "//   backend",
    items: ["Python", "Django", "PostgreSQL", "AWS S3"],
    chipClass: "accent2",
  },
  { label: "//   geospatial", items: ["GIS", "Leaflet"], chipClass: "geo" },
];

const qualifications = [
  {
    title: "Level 4 in Python Programming",
    institution: "Techno Camp, Swansea University",
    grade: "",
    Date: "2026",
  },
  {
    title: "Level 5 Diploma in Web Application development",
    institution: "Code Institute",
    grade: "Distiction",
    Date: "2024",
  },
];
---

<style>
  .container {
    font-family: system-ui, sans-serif;
    line-height: 1.6;
  }

  .intro {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    line-height: 1.8rem;
  }

  .intro p {
    margin-bottom: 1.8rem;
  }

  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .skills li {
    background: #4c7fe5;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    text-align: centre;
    color: var(--skillColor);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }

  .qualification-badge {
    display: flex;
    gap: 2rem;
    border: 1px solid var(--accent2);
    background-color: rgba(129, 140, 248, 0.1);
    border-radius: 6px;
    margin-top: 2rem;
    padding: 0.6rem 1rem;
    align-items: center;
  }

  /* .qualification-badge:nth-child(odd) {
    background-color: rgba(248, 113, 113, 0.1);
    border: 1px solid rgba(248, 113, 113, 0.4);
  } */

  .qualification-icon::before {
    content: "🎓";
    font-size: 2rem;
  }

  .qualification {
    min-width: 0;
  }

  .qualification-title {
    color: var(--text);
  }

  .qualifcation-info {
    display: flex;
    color: var(--accent2);
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }

  .separator {
    padding: 0 0.5rem;
  }

  .skills-group {
    margin-bottom: 1.5rem;
  }

  .skills-group-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }

  .skills-list {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .skill-chip {
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
  }

  .skill-chip.accent {
    border-color: rgba(56, 189, 248, 0.3);
    color: var(--accent);
    background: rgba(56, 189, 248, 0.06);
  }

  .skill-chip.accent2 {
    border-color: rgba(129, 140, 248, 0.3);
    color: var(--accent2);
    background: rgba(129, 140, 248, 0.06);
  }

  .skill-chip.geo {
    border-color: rgba(74, 222, 128, 0.3);
    color: #4ade80;
    background: rgba(74, 222, 128, 0.06);
  }

  @media screen and (min-width: 636px) {
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }
</style>

<BaseLayout>
  <section>
    <div class="container">
      <p class="section-label">About Me</p>
      <h2 class="section-title">{pageTitle}</h2>
      <div class="section-divider"></div>

      <div class="about-grid">
        <div class="about-text">
          <div class="intro">
            <p>
              I'm a <strong>junior full-stack developer</strong> with a strong interest
              in geospatial technology and data-driven web applications. I work with
              HTML, CSS, JavaScript, and Python, and have experience with frameworks
              including Django, React, and jQuery, as well as Leaflet for interactive
              mapping.
            </p>

            <p>
              With a background in <strong>archaeology and GIS</strong>, I'm
              used to working with complex spatial data and thinking carefully
              about how it can be made easier to explore and understand. I'm
              especially drawn to projects that use technology to help people
              connect with landscapes, heritage, and place.
            </p>

            <p>
              I'm familiar with <strong>PostgreSQL and PostGIS</strong>, with a
              particular focus on spatial data and the web tools that bring it
              to life.
            </p>
          </div>

          {
            qualifications.map((qualification) => (
              <div class="qualification-badge">
                {/* icon */}
                <div class="qualification-icon" />

                {/* details */}
                <div class="qualification">
                  <div class="qualification-title">
                    {qualification.title}
                    {qualification.Date && <span> ({qualification.Date})</span>}
                  </div>

                  <div class="qualifcation-info">
                    {qualification.institution && (
                      <span>{qualification.institution}</span>
                    )}

                    {qualification.grade && (
                      <span>
                        <span class="separator">|</span>
                        {qualification.grade}
                      </span>
                    )}
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <div class="about-skills">
          {
            skillGroups.map((group) => (
              <div class="skills-group">
                <p class="skills-group-label">{group.label}</p>

                <ul class="skills-list">
                  {group.items.map((item) => (
                    <li class={`skill-chip ${group.chipClass}`}>{item}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
