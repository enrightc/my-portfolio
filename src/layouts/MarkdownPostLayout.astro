---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---

<BaseLayout>
  <main class="container">
    <img src={frontmatter.image.url} width="500" alt="{frontmatter.image.alt" />
    <h1>{frontmatter.title}</h1>
    <p>Published: {frontmatter.pubDate}</p>
    <p>Github: {frontmatter.github}</p>
    <p>Live site: {frontmatter.livesite}</p>
    <slot />
  </main>
</BaseLayout>
