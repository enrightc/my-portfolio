---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---

<BaseLayout>
  <section class="container">
    <img
      src={frontmatter.image.url}
      alt={frontmatter.image.alt}
      class="cover-image"
    />

    <div class="project-detail">
      <p class="section-label">Project</p>
      <h1>{frontmatter.title}</h1>
      <div class="project-info">
        <p>
          {
            frontmatter.pubDate.toLocaleDateString("en-GB", {
              month: "long",
              year: "numeric",
            })
          }
        </p>
        <p>{frontmatter.minutes} min read</p>
      </div>

      <div class="tags">
        {
          frontmatter.tags.map((tag: string) => (
            <p class="tag">
              <a href={`/tags/${tag}`}>{tag}</a>
            </p>
          ))
        }
      </div>

      <div class="project-links">
        <a
          href={frontmatter.github}
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer">Github</a
        >
        <a
          href={frontmatter.livesite}
          class="btn btn-secondary"
          target="_blank"
          rel="noopener noreferrer">Live Site</a
        >
      </div>

      <div class="section-divider"></div>
    </div>

    <div class="project-body">
      <slot />
    </div>
  </section>
</BaseLayout>

<style>
  .project-detail h1 {
    margin: 0;
  }

  .project-detail p.section-label {
    margin: 0;
  }

  .project-detail {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-detail .project-info {
    margin-top: 0.5rem;
  }

  .project-detail .project-links {
    margin-top: 1.5rem;
  }

  .project-detail .section-divider {
    margin-top: 1.5rem;
  }

  .cover-image {
    width: 100%;
    height: auto;
    border-radius: 10px;
    margin-bottom: 1.5rem;
    display: block;
  }

  .project-info {
    display: flex;
    gap: 0.75em;
  }

  .project-info p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
  }

  .project-info p + p::before {
    content: "·";
    margin-right: 0.75rem;
    color: var(--muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
  }

  .tag a {
    text-decoration: none;
    color: var(--accent2);
    cursor: pointer;
  }

  .tag {
    margin: 0.25em;
    font-family: var(--font-mono);
    font-size: 1rem;
    border: rgba(129, 140, 248, 0.3) solid 1px;
    border-radius: 0.5em;
    padding: 0.4rem 0.8rem;
    background-color: rgba(129, 140, 248, 0.06);
  }

  .project-links {
    display: flex;
    gap: 2rem;
  }

  /* ---------------------*/
  /* Navigation */
  /* ---------------------*/

  .project-body {
    max-width: 70ch;
    margin-bottom: 2rem;
  }

  :global(.project-body h2) {
    color: var(--text);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 2.5rem 0 0.75rem;
    text-transform: capitalize;
  }

  :global(.project-body p) {
    color: var(--text);
    line-height: 1.7;
    margin: 0 0 1.25rem;
  }

  :global(.project-body ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0 0 1.5rem;
  }

  :global(.project-body li) {
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  :global(.project-body li::marker) {
    color: var(--accent);
  }

  :global(.project-body hr) {
    border: 0;
    width: 3rem;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    margin: 3rem 0;
  }
</style>
